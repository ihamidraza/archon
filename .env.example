# ──────────────────────────────────────────────────────────────────────────
# Archon configuration — copy to `.env` and adjust.
# Everything defaults to a fully-local, zero-cost setup.
# ──────────────────────────────────────────────────────────────────────────

# --- Ollama (local LLM server) ---
OLLAMA_BASE_URL=http://localhost:11434

# Tiered models (route work by cost/latency):
#   ROUTER  -> fast classification + guardrail checks
#   AGENT   -> specialist answering (reasoning + tool calling)
#   EMBED   -> embeddings for RAG
ARCHON_ROUTER_MODEL=llama3.2:3b
ARCHON_AGENT_MODEL=qwen3.6:latest
ARCHON_EMBED_MODEL=nomic-embed-text
# Lower temperature -> more deterministic routing/guardrails
ARCHON_ROUTER_TEMPERATURE=0.0
ARCHON_AGENT_TEMPERATURE=0.3

# --- RAG / vector store ---
ARCHON_CHROMA_DIR=backend/data/chroma
ARCHON_CHROMA_COLLECTION=archon_kb
ARCHON_KB_DIR=backend/data/knowledge_base
ARCHON_RAG_TOP_K=4

# --- Memory / checkpointer ---
ARCHON_CHECKPOINT_DB=backend/data/checkpoints.sqlite

# --- Guardrail thresholds ---
ARCHON_ROUTER_CONFIDENCE_THRESHOLD=0.5
ARCHON_MAX_OUTPUT_RETRIES=1

# --- API + ops ---
# Comma-separated CORS allow-list (the Next.js dev server by default).
ARCHON_API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Per-IP rate limit for the streaming endpoints.
ARCHON_API_RATE_LIMIT=30/minute
# Max characters accepted in a single message.
ARCHON_API_MAX_MESSAGE_CHARS=4000
# Per-request timeout (seconds) for model calls.
ARCHON_REQUEST_TIMEOUT=120
# Log level: DEBUG | INFO | WARNING | ERROR
ARCHON_LOG_LEVEL=INFO

# --- LangSmith observability (free Developer tier) ---
# Get a key at https://smith.langchain.com (Settings -> API Keys)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls-...replace-me...
LANGCHAIN_PROJECT=archon
